{
  "name": "miniapp-template",
  "version": "0.0.1",
  "private": true,
  "homepage": "https://github.com/Mister-Hope/miniapp-template",
  "bugs": {
    "url": "https://github.com/Mister-Hope/miniapp-template/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inNENU/inNENU.git"
  },
  "type": "module",
  "scripts": {
    "build": "gulp -f gulpfile.cjs build",
    "clean": "unrun ./scripts/del.ts",
    "dev": "gulp -f gulpfile.cjs watch",
    "lint": "pnpm lint:oxlint --fix && oxfmt && pnpm lint:wxs --write && pnpm lint:wxml --write && pnpm lint:stylelint --fix",
    "lint:oxlint": "oxlint --deny-warnings --report-unused-disable-directives",
    "lint:stylelint": "stylelint **/*.scss",
    "lint:wxml": "prettier --check --parser html **/*.wxml",
    "lint:wxs": "prettier --check --parser babel-flow **/*.wxs",
    "prepare": "husky"
  },
  "dependencies": {
    "@mptool/all": "0.14.0"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@mr-hope/tsconfig": "0.0.4",
    "del": "8.0.1",
    "gulp": "5.0.1",
    "gulp-rename": "2.1.0",
    "gulp-replace": "1.1.4",
    "gulp-sourcemaps": "3.0.0",
    "gulp-typescript": "6.0.0-alpha.1",
    "gulp5-sass-plugin": "2.1.0",
    "husky": "9.1.7",
    "innenu-generator": "0.8.2",
    "miniprogram-api-typings": "5.1.3",
    "nano-staged": "1.0.2",
    "oxc-config-hope": "0.3.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "postcss": "^8.5.10",
    "prettier": "3.8.3",
    "stylelint": "17.8.0",
    "stylelint-config-hope": "11.0.0",
    "tsdown": "0.21.9",
    "typescript": "6.0.3",
    "unrun": "0.2.36"
  },
  "nano-staged": {
    "**/*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "oxlint --fix --deny-warnings --report-unused-disable-directives",
    "*.scss": "stylelint --fix",
    "*.wxml": "prettier --parser html --write",
    "*.wxs": "prettier --parser babel-flow --write"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "prettier": {
    "overrides": [
      {
        "files": "**/*.wxml",
        "options": {
          "parser": "html"
        }
      },
      {
        "files": "**/*.wxs",
        "options": {
          "parser": "babel-flow"
        }
      }
    ]
  },
  "packageManager": "pnpm@10.33.0"
}
